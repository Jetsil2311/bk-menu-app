rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public menu reads ─────────────────────────────────────────────────────
    // Anyone can read menu content so the public-facing menu loads without login.
    // Only authenticated admins can write (add/edit/delete products, sections, etc.)

    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /sections/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /toppings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /promotions/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /carousel/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /combos/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    // The public menu creates an order snapshot when a customer sends via WhatsApp.
    // Admins can read, update, and delete orders in the admin panel.

    match /orders/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── Admin-only collections ────────────────────────────────────────────────
    // Everything below is only accessible to authenticated admin users.

    match /customers/{doc} {
      allow read, write: if request.auth != null;
    }

    match /register_sessions/{doc} {
      allow read, write: if request.auth != null;
    }

    match /parked_orders/{doc} {
      allow read, write: if request.auth != null;
    }

    match /settings/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
